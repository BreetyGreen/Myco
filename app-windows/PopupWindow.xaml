<Window x:Class="Myco.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Myco" Width="396" Height="640"
        WindowStyle="None" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True"
        ShowActivated="True" FontFamily="Segoe UI">

    <!-- 无边框但不启用 WPF 分层透明：这样 Win11 的 DWM acrylic 背板（GlassHelper）
         才能生效，并由系统提供圆角与投影。 -->
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1" CaptionHeight="0"
                      ResizeBorderThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <!-- 半透明品牌色染层：叠在 acrylic 模糊之上（acrylic 不可用时代码回退为不透明） -->
        <Border x:Name="TintBase" Background="{DynamicResource WallGrad}"/>
        <Border Background="{DynamicResource PanelGrad}"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ======== 品牌头 ======== -->
            <Grid Grid.Row="0" Margin="16,14,16,12">
                <StackPanel Orientation="Horizontal">
                    <!-- BrandMark：三层叠 chip -->
                    <Grid Width="26" Height="26" VerticalAlignment="Center">
                        <Border Width="16" Height="16" CornerRadius="5"
                                BorderBrush="{DynamicResource Brand}" BorderThickness="1.4"
                                Opacity="0.55" Margin="-8,-9,0,0"/>
                        <Border Width="16" Height="16" CornerRadius="5"
                                BorderBrush="{DynamicResource BrandLite}" BorderThickness="1.4"
                                Opacity="0.6" Margin="7,-2,0,0"/>
                        <Border Width="18" Height="18" CornerRadius="5"
                                Background="{DynamicResource BrandGrad}" Margin="-1,8,0,0"/>
                    </Grid>
                    <StackPanel Margin="9,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="16" FontWeight="SemiBold">
                            <Run Text="my" Foreground="{DynamicResource Text}"/><Run Text="co" Foreground="{DynamicResource Brand}"/>
                        </TextBlock>
                        <TextBlock Text="the mycelial layer for your agents"
                                   FontSize="10.5" Foreground="{DynamicResource Text3}"/>
                    </StackPanel>
                </StackPanel>
                <!-- 主题切换 -->
                <Button x:Name="ThemeBtn" Style="{StaticResource FlatBtn}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="OnToggleTheme">
                    <Border Width="30" Height="30" CornerRadius="15"
                            Background="{DynamicResource Card2}">
                        <TextBlock x:Name="ThemeGlyph" Text="&#xE706;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Text2}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Button>
            </Grid>

            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                    Background="{DynamicResource LineSoft}"/>

            <!-- ======== 内容区 ======== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ContentControl x:Name="ContentHost" Margin="16"/>
            </ScrollViewer>

            <!-- ======== 底部 Tab ======== -->
            <Border Grid.Row="2" Background="{DynamicResource Card2}"
                    BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0">
                <UniformGrid Rows="1" Margin="10,8,10,10">
                    <Button x:Name="TabHome" Style="{StaticResource FlatBtn}" Click="OnTab" Tag="home"/>
                    <Button x:Name="TabShare" Style="{StaticResource FlatBtn}" Click="OnTab" Tag="share"/>
                    <Button x:Name="TabRelay" Style="{StaticResource FlatBtn}" Click="OnTab" Tag="relay"/>
                    <Button x:Name="TabHistory" Style="{StaticResource FlatBtn}" Click="OnTab" Tag="history"/>
                    <Button x:Name="TabSettings" Style="{StaticResource FlatBtn}" Click="OnTab" Tag="settings"/>
                </UniformGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
