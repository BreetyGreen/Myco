<UserControl x:Class="Myco.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Ellipse Width="5" Height="5" Fill="{DynamicResource Brand}" VerticalAlignment="Center"/>
            <TextBlock Text="设置" FontSize="10.5" FontWeight="SemiBold" Margin="7,0,0,0"
                       Foreground="{DynamicResource Brand}"/>
        </StackPanel>

        <!-- 外观主题 -->
        <Border CornerRadius="14" Background="{DynamicResource Card}" Padding="13" Margin="0,0,0,12"
                BorderBrush="{DynamicResource LineSoft}" BorderThickness="0.6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="外观主题" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text}"/>
                    <TextBlock x:Name="ThemeLabel" Text="深色" FontSize="11"
                               Foreground="{DynamicResource Text3}"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource FlatBtn}" Click="OnToggleTheme"
                        VerticalAlignment="Center">
                    <Border CornerRadius="14" Background="{DynamicResource BrandTint}" Padding="12,7">
                        <TextBlock x:Name="ThemeBtnLabel" Text="深色" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brand}"/>
                    </Border>
                </Button>
            </Grid>
        </Border>

        <!-- 路径 -->
        <Border CornerRadius="14" Background="{DynamicResource Card}" Padding="13" Margin="0,0,0,12"
                BorderBrush="{DynamicResource LineSoft}" BorderThickness="0.6">
            <StackPanel>
                <TextBlock Text="脚本资源（只读）" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text}" Margin="0,0,0,4"/>
                <TextBlock x:Name="ResourcePath" FontSize="10.5" FontFamily="Consolas"
                           TextWrapping="Wrap" Foreground="{DynamicResource Text3}" Margin="0,0,0,8"/>
                <Border Height="1" Background="{DynamicResource LineSoft}" Margin="0,0,0,8"/>
                <TextBlock Text="输出目录（接力包 / 归档 / 分发）" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text}" Margin="0,0,0,4"/>
                <TextBlock x:Name="WorkPath" FontSize="10.5" FontFamily="Consolas"
                           TextWrapping="Wrap" Foreground="{DynamicResource Text3}" Margin="0,0,0,8"/>
                <Border Height="1" Background="{DynamicResource LineSoft}" Margin="0,0,0,8"/>
                <TextBlock Text="Python 解释器" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text}" Margin="0,0,0,4"/>
                <TextBlock x:Name="PythonPath" FontSize="10.5" FontFamily="Consolas"
                           TextWrapping="Wrap" Foreground="{DynamicResource Text3}" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource GhostBtn}" Click="OnRefresh"
                            Content="重新检测" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource GhostBtn}" Click="OnOpenWorkDir"
                            Content="打开输出目录"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 落款 -->
        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
            <Grid Width="22" Height="22" VerticalAlignment="Center">
                <Border Width="13" Height="13" CornerRadius="4"
                        BorderBrush="{DynamicResource Brand}" BorderThickness="1.2"
                        Opacity="0.55" Margin="-7,-8,0,0"/>
                <Border Width="13" Height="13" CornerRadius="4"
                        BorderBrush="{DynamicResource BrandLite}" BorderThickness="1.2"
                        Opacity="0.6" Margin="6,-2,0,0"/>
                <Border Width="15" Height="15" CornerRadius="4"
                        Background="{DynamicResource BrandGrad}" Margin="-1,7,0,0"/>
            </Grid>
            <StackPanel Margin="9,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Myco" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text}"/>
                <TextBlock Text="the mycelial layer for your agents · v0.4 (Windows)"
                           FontSize="10" Foreground="{DynamicResource Text3}"/>
            </StackPanel>
        </StackPanel>

    </StackPanel>
</UserControl>
