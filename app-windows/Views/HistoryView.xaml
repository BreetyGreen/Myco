<UserControl x:Class="Myco.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Ellipse Width="5" Height="5" Fill="{DynamicResource Brand}" VerticalAlignment="Center"/>
            <TextBlock Text="历史浏览" FontSize="10.5" FontWeight="SemiBold" Margin="7,0,0,0"
                       Foreground="{DynamicResource Brand}"/>
        </StackPanel>

        <TextBlock Text="跨 agent 聊天记录聚合" FontSize="15" FontWeight="SemiBold"
                   Foreground="{DynamicResource Text}" Margin="0,0,0,4"/>
        <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Text2}" Margin="0,0,0,12"
                   Text="把所有 agent 的历史聚合成一份中性、可搜索、可备份的归档，并生成离线 HTML 时间线。全程只读。"/>

        <ItemsControl x:Name="InstalledList" Margin="0,0,0,12">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="11" Background="{DynamicResource Card2}" Margin="0,0,0,7"
                            Padding="11,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="26" Height="26" CornerRadius="7"
                                    Background="{Binding Badge}">
                                <TextBlock Text="{Binding Initial}" FontSize="12" FontWeight="ExtraBold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Display}" FontSize="13"
                                       FontWeight="Medium" Margin="11,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Text}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CountLabel}" FontSize="12.5" FontWeight="Bold"
                                           Foreground="{DynamicResource Brand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button x:Name="SyncBtn" Style="{StaticResource PrimaryBtn}" Click="OnSync"
                Content="聚合并生成时间线" Margin="0,0,0,12"/>

        <Border x:Name="ResultCard" CornerRadius="11" Background="{DynamicResource Card2}"
                Padding="11" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="3" CornerRadius="2" Background="{DynamicResource Brand}"/>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="归档完成" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brand}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="ResultText" FontSize="11" FontFamily="Consolas"
                               TextWrapping="Wrap" Foreground="{DynamicResource Text2}"/>
                </StackPanel>
            </Grid>
        </Border>

    </StackPanel>
</UserControl>
